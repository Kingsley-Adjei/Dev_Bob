# DevAssist API Configuration
# Copy this file to .env and update with your values

# Application Settings
APP_NAME=DevAssist
DEBUG=true
HOST=0.0.0.0
PORT=8000

# API Keys (comma-separated list of valid API keys)
# Generate secure keys for production use
API_KEYS=dev-key-123,test-key-456,prod-key-789

# CORS Origins (comma-separated list of allowed origins)
# Add your frontend URLs here
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000



# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAVNIc85mtqQOmm9tXUO_KlyUkC1xWD27U
